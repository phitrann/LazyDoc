{
  "version": 2,
  "buildCommand": "npm run build --prefix frontend && pip install -r backend/requirements.txt",
  "env": {
    "BACKEND_INTERNAL_URL": "@backend_internal_url"
  },
  "functions": {
    "backend/app/main.py": {
      "runtime": "python3.11"
    },
    "frontend/src/app/api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(?<path>.*)",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
