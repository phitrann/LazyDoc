# GitHub API Configuration
# Personal access token for GitHub API requests. Generate at: https://github.com/settings/tokens
# Required for higher rate limits (5000/hour vs 60/hour unauthenticated)
GITHUB_TOKEN=

# GitHub API timeout in seconds (default: 15)
GITHUB_TIMEOUT_SECONDS=15

# GitHub API base URL (default: https://api.github.com)
# Override only if using GitHub Enterprise
GITHUB_API_BASE_URL=https://api.github.com

# User agent for GitHub API requests (default: AutoDocResearchTool/1.0)
GITHUB_USER_AGENT=AutoDocResearchTool/1.0

# Cache Configuration
# Cache TTL for repository analysis in seconds (default: 1800 = 30 minutes)
CACHE_TTL_SECONDS=1800

# Enable long-term caching for documentation (default: false)
# Set to "true", "1", or "yes" to enable
ENABLE_LONG_CACHE=false

# Long-term cache TTL in seconds (default: 86400 = 24 hours)
# Only used if ENABLE_LONG_CACHE is enabled
LONG_CACHE_TTL_SECONDS=86400

# Local LLM Configuration
# Base URL for local LLM service (e.g., ollama, vLLM)
# Default: http://localhost:8001/v1
# For Vercel deployment: provide cloud-hosted LLM URL or leave empty to disable
LOCAL_LLM_BASE_URL=http://localhost:8001/v1

# Model name for LLM (default: Qwen/Qwen3.5-4B)
# Must match model available on your LLM service
LOCAL_LLM_MODEL=Qwen/Qwen3.5-4B

# Local Embedding Service Configuration
# Base URL for embedding service (e.g., ollama, sentence-transformers)
# Default: http://localhost:8002/v1
# For Vercel deployment: provide cloud-hosted embedding URL or leave empty to disable
LOCAL_EMBEDDING_BASE_URL=http://localhost:8002/v1

# Model name for embeddings (default: BAAI/bge-m3)
# Must match model available on your embedding service
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3

# API Key for OpenAI-compatible LLM services (default: not_used)
# Only needed if using cloud-hosted LLM/embedding services that require authentication
OPENAI_API_KEY=not_used
